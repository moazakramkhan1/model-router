# ── Local model (e.g. Ollama) ────────────────────────────────────────────────
LOCAL_MODEL=hf.co/unsloth/Qwen3-1.7B-GGUF:Q4_K_M
LOCAL_BASE_URL=http://ollama:11434

# ── Mid-tier API (e.g. Groq) ──────────────────────────────────────────────────
MID_API_KEY=your_mid_tier_api_key_here
MID_MODEL=llama-3.1-8b-instant

# ── Premium API (e.g. Gemini) ─────────────────────────────────────────────────
PREMIUM_API_KEY=your_premium_api_key_here
PREMIUM_MODEL=gemini-1.5-flash

# ── Router security ────────────────────────────────────────────────────────
# Leave empty for open access (dev). Set a strong secret for production.
ROUTER_API_KEY=
# Requests per minute per IP (slowapi syntax)
RATE_LIMIT=60/minute

# ── Caching ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=300

# ── Evaluation ────────────────────────────────────────────────────────────────
# Set to false to skip the tiny LLM judge and use rules-only scoring
USE_LLM_JUDGE=true
LLM_JUDGE_TIMEOUT_S=25

# ── Circuit breaker ───────────────────────────────────────────────────────────
CB_FAIL_MAX=3
CB_RESET_TIMEOUT_S=30

# ── OpenTelemetry (optional) ────────────────────────────────────────────────────
# Leave empty to emit traces to stdout. Set to your OTLP collector endpoint.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Set to "none" to disable tracing entirely
OTEL_TRACES_EXPORTER=console
