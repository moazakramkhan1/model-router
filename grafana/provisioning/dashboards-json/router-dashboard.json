{
    "__inputs": [],
    "__requires": [
        {
            "type": "grafana",
            "id": "grafana",
            "name": "Grafana",
            "version": "10.0.0"
        },
        {
            "type": "datasource",
            "id": "prometheus",
            "name": "Prometheus",
            "version": "1.0.0"
        }
    ],
    "annotations": {
        "list": []
    },
    "description": "Model Router – success rate, cost, attempts, and latency observability",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "id": 1,
            "type": "stat",
            "title": "Success Rate (5m)",
            "description": "Fraction of tasks that produced a passing response in the last 5 minutes.",
            "gridPos": {
                "h": 7,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(router_tasks_total{success=\"true\"}[5m])) / sum(rate(router_tasks_total[5m]))",
                    "legendFormat": "success rate",
                    "instant": true
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0,
                    "max": 1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 0.5
                            },
                            {
                                "color": "green",
                                "value": 0.9
                            }
                        ]
                    },
                    "mappings": []
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "area",
                "justifyMode": "auto"
            }
        },
        {
            "id": 2,
            "type": "stat",
            "title": "Cost per Success (5m)",
            "description": "Virtual cost units spent per successful task over the last 5 minutes.",
            "gridPos": {
                "h": 7,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum(rate(router_virtual_cost_units_total[5m])) / sum(rate(router_tasks_total{success=\"true\"}[5m]))",
                    "legendFormat": "cost/success",
                    "instant": true
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "decimals": 2,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 10
                            },
                            {
                                "color": "red",
                                "value": 30
                            }
                        ]
                    },
                    "mappings": []
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "area",
                "justifyMode": "auto"
            }
        },
        {
            "id": 3,
            "type": "timeseries",
            "title": "Attempts by Model (rate/s)",
            "description": "Per-model attempt rate, split by outcome (ok=true/false).",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 7
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum by (model, ok) (rate(router_attempts_total[5m]))",
                    "legendFormat": "{{model}} ok={{ok}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10,
                        "showPoints": "auto",
                        "spanNulls": false
                    }
                },
                "overrides": []
            },
            "options": {
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                },
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom",
                    "showLegend": true
                }
            }
        },
        {
            "id": 4,
            "type": "timeseries",
            "title": "p95 Latency by Model (ms)",
            "description": "95th-percentile provider call latency per model slot.",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 7
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.95, sum by (le, model) (rate(router_latency_ms_bucket[5m])))",
                    "legendFormat": "p95 {{model}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ms",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10,
                        "showPoints": "auto",
                        "spanNulls": false
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 2000
                            },
                            {
                                "color": "red",
                                "value": 4000
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                },
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom",
                    "showLegend": true
                }
            }
        }
    ],
    "refresh": "30s",
    "schemaVersion": 39,
    "tags": [
        "router",
        "llm",
        "cost"
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-30m",
        "to": "now"
    },
    "timepicker": {},
    "timezone": "browser",
    "title": "Model Router",
    "uid": "model-router-v1",
    "version": 1,
    "weekStart": ""
}